#!/bin/bash

# このスクリプトは tshark を使って TLS 通信のパケットをキャプチャし、
# その内容を詳細表示したうえで log ファイルに保存するためのものです。
#
# 想定している用途:
# - TLS ハンドシェイクの観察
# - OpenSSL s_client などで接続したときの通信内容確認
# - Docker コンテナ間の HTTPS 通信の解析
#
# このスクリプトは Wireshark GUI を使わず、
# CLI ツール tshark だけでパケット解析を行う構成になっています。


# sudo
# tshark はネットワークインターフェースから直接パケットを取得するため、
# 通常 root 権限が必要になります。
#
# tshark
# Wireshark の CLI 版で、パケットキャプチャとプロトコル解析を行うツールです。
#
# -i eth0
# キャプチャするネットワークインターフェースを指定します。
# Docker コンテナ内では通常 eth0 が外部通信インターフェースになります。
#
# port 10443
# キャプチャフィルタです。
# TCP/UDP ポート 10443 の通信だけを取得します。
#
# この環境では 10443 は HTTPS/TLS の検証用ポートとして使われています。
#
# -V
# パケットを詳細表示します。
# 通常の一覧表示ではなく、次のようなプロトコル階層を展開します。
#
#   Ethernet
#   IP
#   TCP
#   TLS
#   TLS Handshake
#
# これにより TLS の ClientHello / ServerHello / Certificate などを確認できます。
#
# | tee log
# tee コマンドは、標準出力を
#
#   ・画面に表示
#   ・log ファイルに保存
#
# の両方に出力します。
#
# TLS 実験では後からログを確認できるようにすることが重要なため、
# このような構成にしています。
#
# なお tee -a log にするとログを追記モードにできます。
#
# 実行を停止する場合は Ctrl + C を押します。


sudo tshark -i eth0 port 10443 -V | tee log_tshark
